# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# secrets / API keys
.secrets/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Office temp files
~$*

# Business documents (not code)
vassweb-dokumenty/
*.docx
*.pdf
*.jsonl

# Sync & setup scripts (local only)
cloud-sync/
cloudflare-dns-setup.sh
vercel-domains-setup.sh
thunderbolt-sync.sh
chrome-bookmarks.html
Vassweb-email-podpis.html
